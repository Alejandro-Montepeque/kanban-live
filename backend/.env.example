# Database
# Note: host port is 5433 in docker-compose (to avoid clash with other local Postgres on 5432)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/kanban

# Redis (only required when running multiple backend instances behind a load balancer)
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=replace_me_with_a_long_random_string
JWT_REFRESH_SECRET=replace_me_with_another_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5174

# Frontend URL used in password-reset / email-verification links
FRONTEND_URL=http://localhost:5174

# Email provider (optional in dev — without it, emails are logged to stdout)
# Get a free key at https://resend.com
RESEND_API_KEY=
MAIL_FROM=kanban-live <no-reply@kanban-live.app>

# Environment
NODE_ENV=development
PORT=3000
