generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  passwordHash         String
  name                 String
  avatarUrl            String?
  emailVerifiedAt      DateTime?
  failedLoginAttempts  Int       @default(0)
  lockedUntil          DateTime?
  passwordChangedAt    DateTime  @default(now())
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  memberships              Membership[]
  authoredCards            Card[]                    @relation("CardAuthor")
  assignedCards            Card[]                    @relation("CardAssignee")
  refreshTokens            RefreshToken[]
  activities               Activity[]
  passwordResetTokens      PasswordResetToken[]
  emailVerificationTokens  EmailVerificationToken[]
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  token     String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  boards      Board[]
  invitations Invitation[]
}

model Invitation {
  id          String    @id @default(cuid())
  token       String    @unique
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String
  email       String?
  role        Role      @default(MEMBER)
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
  @@index([token])
}

model Membership {
  id          String    @id @default(cuid())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String
  role        Role      @default(MEMBER)
  joinedAt    DateTime  @default(now())

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

enum Role {
  OWNER
  MEMBER
}

model Board {
  id          String    @id @default(cuid())
  name        String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  columns    Column[]
  activities Activity[]

  @@index([workspaceId])
}

model Column {
  id       String @id @default(cuid())
  name     String
  position Float
  board    Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId  String

  cards Card[]

  @@index([boardId])
}

model Card {
  id          String    @id @default(cuid())
  title       String
  description String?
  position    Float
  dueDate     DateTime?
  column      Column    @relation(fields: [columnId], references: [id], onDelete: Cascade)
  columnId    String
  author      User      @relation("CardAuthor", fields: [authorId], references: [id])
  authorId    String
  assignee    User?     @relation("CardAssignee", fields: [assigneeId], references: [id])
  assigneeId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([columnId])
}

model Activity {
  id        String   @id @default(cuid())
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId   String
  actor     User     @relation(fields: [actorId], references: [id])
  actorId   String
  action    String
  payload   Json
  createdAt DateTime @default(now())

  @@index([boardId, createdAt])
}
